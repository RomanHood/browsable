<h1>Browsable Example</h1>

<search>
  <form action="/search">
    <label for="q">Search the docs</label>
    <input type="search" id="q" name="q">
  </form>
</search>

<details>
  <summary>What is this?</summary>
  <p>A tiny Rails app for exercising <code>browsable</code>.</p>
</details>

<button popovertarget="info">Show details</button>

<div id="info" popover>
  <p>This panel relies on the HTML <code>popover</code> attribute.</p>
</div>

<dialog>
  <p>And this is a native &lt;dialog&gt; element.</p>
</dialog>
