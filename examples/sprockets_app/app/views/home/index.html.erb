<h1>Browsable Sprockets Example</h1>

<search>
  <form action="/search">
    <label for="q">Search the docs</label>
    <input type="search" id="q" name="q">
  </form>
</search>

<button popovertarget="info">Show details</button>

<div id="info" popover>
  <p>This panel relies on the HTML <code>popover</code> attribute.</p>
</div>
